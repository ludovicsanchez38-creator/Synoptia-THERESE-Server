# ===========================================
# Thérèse Server - Configuration
# Copier vers .env et adapter les valeurs
# ===========================================

# --- Base de données ---
POSTGRES_DB=therese
POSTGRES_USER=therese
POSTGRES_PASSWORD=changeme_en_production

# --- Backend ---
SECRET_KEY=changeme_generate_with_openssl_rand_hex_32
DEBUG=false
HOST=0.0.0.0
PORT=8000

# --- Qdrant ---
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=therese-docs

# --- Chiffrement (Fernet) ---
ENCRYPTION_KEY=changeme_generate_with_python_fernet

# --- Fournisseurs LLM (configurer ceux utilisés) ---
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
OLLAMA_URL=http://host.docker.internal:11434

# --- JWT Auth ---
JWT_SECRET=changeme_generate_with_openssl_rand_hex_32
JWT_LIFETIME_SECONDS=3600
JWT_REFRESH_LIFETIME_SECONDS=604800

# --- RGPD ---
DATA_RETENTION_DAYS=1095
AUDIT_LOG_ENABLED=true

# --- Domaine (pour Caddy HTTPS) ---
DOMAIN=therese.example.com
